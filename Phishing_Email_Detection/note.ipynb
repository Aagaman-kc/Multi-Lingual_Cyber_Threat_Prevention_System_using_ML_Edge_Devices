for lang in test_df['lang'].unique():
    subset = test_df[test_df['lang'] == lang]
    if len(subset) > 10:
        acc_lang = (subset['label'] == subset['pred']).mean()
        print(f"{lang}: {acc_lang:.4f} (n={len(subset)})")
    else:
        print(f"{lang}: insufficient samples ({len(subset)})")

